generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum AgendamentoStatus {
  AguardandoConfirmacao
  Confirmado
  Cancelado
  EmAndamento
  Atrasado
  Pronto
  Finalizado
  NaoCompareceu
}

enum AgendamentoOrigem {
  tutor
  atendente
}

enum PetTutorTipo {
  responsavel
  autorizado
}

enum ConviteStatus {
  pendente
  aceito
  expirado
  revogado
}

enum PetshopUserRole {
  owner
  atendente
  banhista
}

enum NotificacaoCanal {
  email
  push
}

enum NotificacaoTipo {
  agendado
  confirmado
  cancelado
  alterado
}

enum NotificacaoStatus {
  pendente
  enviado
  falha
}

enum AtendimentoServicoOrigem {
  agendamento
  balcao
}

// ---------------------------------------------------------------------------
// Auth & Users
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  firebase_uid String   @unique
  nome         String
  email        String   @unique
  telefone     String?
  cpf          String   @unique
  ativo        Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  tutor_profile      TutorProfile?
  petshop_profiles   PetshopUserProfile[]
  notificacoes       NotificacaoOutbox[]
  registros          RegistroOperacional[]

  @@map("users")
}

model TutorProfile {
  id         String   @id @default(uuid())
  user_id    String   @unique
  endereco   String?
  ativo      Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  user        User          @relation(fields: [user_id], references: [id])
  pet_tutores PetTutor[]
  convites    PetTutorConvite[] @relation("ConviteConvitador")
  agendamentos Agendamento[]

  @@map("tutor_profiles")
}

model PetshopUserProfile {
  id          String            @id @default(uuid())
  user_id     String
  petshop_id  String
  roles       PetshopUserRole[]
  ativo       Boolean           @default(true)
  created_at  DateTime          @default(now()) @db.Timestamptz
  updated_at  DateTime          @updatedAt @db.Timestamptz

  user        User     @relation(fields: [user_id], references: [id])
  petshop     PetShop  @relation(fields: [petshop_id], references: [id])

  agendamentos_como_banhista Agendamento[]  @relation("BanistaAgendamento")
  atendimentos_como_banhista Atendimento[]  @relation("BanistaAtendimento")

  @@unique([user_id, petshop_id])
  @@map("petshop_user_profiles")
}

// ---------------------------------------------------------------------------
// Catálogo Global (admin sistema)
// ---------------------------------------------------------------------------

model TipoAnimal {
  id         String   @id @default(uuid())
  nome       String   @unique
  ativo      Boolean  @default(true)
  ordem      Int?
  created_at DateTime @default(now()) @db.Timestamptz

  racas Raca[]
  pets  Pet[]

  @@map("tipos_animal")
}

model Raca {
  id             String   @id @default(uuid())
  tipo_animal_id String
  nome           String
  ativo          Boolean  @default(true)
  ordem          Int?
  created_at     DateTime @default(now()) @db.Timestamptz

  tipo_animal      TipoAnimal       @relation(fields: [tipo_animal_id], references: [id])
  pets             Pet[]
  servico_variantes ServicoVariante[]

  @@unique([tipo_animal_id, nome])
  @@map("racas")
}

model Porte {
  id         String   @id @default(uuid())
  nome       String   @unique
  ativo      Boolean  @default(true)
  ordem      Int?
  created_at DateTime @default(now()) @db.Timestamptz

  pets              Pet[]
  servico_variantes ServicoVariante[]
  pacote_variantes  PacoteVariante[]

  @@map("portes")
}

model Pelagem {
  id         String   @id @default(uuid())
  nome       String   @unique
  ativo      Boolean  @default(true)
  ordem      Int?
  created_at DateTime @default(now()) @db.Timestamptz

  pets              Pet[]
  servico_variantes ServicoVariante[]
  pacote_variantes  PacoteVariante[]

  @@map("pelagens")
}

// ---------------------------------------------------------------------------
// Pets
// ---------------------------------------------------------------------------

model Pet {
  id                 String   @id @default(uuid())
  tipo_animal_id     String
  nome               String
  raca_id            String?
  porte_id           String?
  pelagem_id         String?
  idade              Int?
  peso               Decimal? @db.Decimal(5, 2)
  agressivo          Boolean  @default(false)
  cuidados_especiais String?
  obs_internas       Json     @default("{}")  // { "<petshop_id>": "texto" }
  obs_compartilhadas Json     @default("{}")  // { "<petshop_id>": "texto" }
  deleted_at         DateTime? @db.Timestamptz
  created_at         DateTime @default(now()) @db.Timestamptz
  updated_at         DateTime @updatedAt @db.Timestamptz

  tipo_animal  TipoAnimal  @relation(fields: [tipo_animal_id], references: [id])
  raca         Raca?       @relation(fields: [raca_id], references: [id])
  porte        Porte?      @relation(fields: [porte_id], references: [id])
  pelagem      Pelagem?    @relation(fields: [pelagem_id], references: [id])

  pet_tutores  PetTutor[]
  convites     PetTutorConvite[]
  pacote_pets  PacotePet[]
  agendamentos Agendamento[]

  @@map("pets")
}

model PetTutor {
  id                 String       @id @default(uuid())
  pet_id             String
  tutor_profile_id   String
  tipo               PetTutorTipo @default(responsavel)
  created_at         DateTime     @default(now()) @db.Timestamptz

  pet           Pet          @relation(fields: [pet_id], references: [id])
  tutor_profile TutorProfile @relation(fields: [tutor_profile_id], references: [id])

  @@unique([pet_id, tutor_profile_id])
  @@map("pet_tutores")
}

model PetTutorConvite {
  id                          String        @id @default(uuid())
  pet_id                      String
  convitador_tutor_profile_id String
  convidado_email             String
  convidado_tutor_profile_id  String?
  token_hash                  String        @unique
  status                      ConviteStatus @default(pendente)
  expires_at                  DateTime      @db.Timestamptz
  created_at                  DateTime      @default(now()) @db.Timestamptz
  accepted_at                 DateTime?     @db.Timestamptz

  pet                Pet          @relation(fields: [pet_id], references: [id])
  convitador         TutorProfile @relation("ConviteConvitador", fields: [convitador_tutor_profile_id], references: [id])

  @@map("pet_tutor_convites")
}

// ---------------------------------------------------------------------------
// PetShop
// ---------------------------------------------------------------------------

model PetShop {
  id              String   @id @default(uuid())
  nome_exibicao   String
  razao_social    String
  cnpj            String   @unique
  endereco        String
  cidade          String
  estado          String   @db.Char(2)
  telefone        String?
  email           String
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)
  config_json     Json     @default("{\"schema_version\": 2}")
  ativo           Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz

  funcionarios     PetshopUserProfile[]
  categorias       CategoriaServico[]
  servicos         Servico[]
  pacotes          Pacote[]
  agendamentos     Agendamento[]
  bloqueios        BloqueioAgenda[]
  registros        RegistroOperacional[]

  @@map("petshops")
}

// ---------------------------------------------------------------------------
// Serviços & Pacotes
// ---------------------------------------------------------------------------

model CategoriaServico {
  id         String   @id @default(uuid())
  petshop_id String
  nome       String
  ordem      Int?
  ativo      Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz

  petshop  PetShop   @relation(fields: [petshop_id], references: [id])
  servicos Servico[]

  @@map("categorias_servico")
}

model Servico {
  id           String   @id @default(uuid())
  petshop_id   String
  categoria_id String?
  nome         String
  descricao    String?
  ativo        Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  petshop   PetShop           @relation(fields: [petshop_id], references: [id])
  categoria CategoriaServico? @relation(fields: [categoria_id], references: [id])
  variantes ServicoVariante[]

  @@map("servicos")
}

model ServicoVariante {
  id               String   @id @default(uuid())
  servico_id       String
  porte_id         String?
  raca_id          String?
  pelagem_id       String?
  duracao_minutos  Int
  preco            Decimal  @db.Decimal(12, 2)
  ativo            Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz

  servico  Servico  @relation(fields: [servico_id], references: [id])
  porte    Porte?   @relation(fields: [porte_id], references: [id])
  raca     Raca?    @relation(fields: [raca_id], references: [id])
  pelagem  Pelagem? @relation(fields: [pelagem_id], references: [id])

  agendamento_servicos   AgendamentoServico[]
  atendimento_servicos   AtendimentoServico[]
  pacote_items           PacoteItem[]

  @@map("servico_variantes")
}

model Pacote {
  id                  String   @id @default(uuid())
  petshop_id          String
  nome                String
  descricao           String?
  travado             Boolean  @default(true)
  desconto_percentual Decimal? @db.Decimal(5, 2)
  validade            DateTime? @db.Date
  ativo               Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz
  updated_at          DateTime @updatedAt @db.Timestamptz

  petshop   PetShop          @relation(fields: [petshop_id], references: [id])
  variantes PacoteVariante[]
  items     PacoteItem[]
  pets      PacotePet[]

  @@map("pacotes")
}

model PacoteVariante {
  id          String   @id @default(uuid())
  pacote_id   String
  porte_id    String?
  pelagem_id  String?
  valor_total Decimal  @db.Decimal(12, 2)
  created_at  DateTime @default(now()) @db.Timestamptz

  pacote  Pacote   @relation(fields: [pacote_id], references: [id])
  porte   Porte?   @relation(fields: [porte_id], references: [id])
  pelagem Pelagem? @relation(fields: [pelagem_id], references: [id])

  @@map("pacote_variantes")
}

model PacoteItem {
  id                 String   @id @default(uuid())
  pacote_id          String
  servico_variante_id String
  quantidade_total   Int
  quantidade_usada   Int      @default(0)
  created_at         DateTime @default(now()) @db.Timestamptz

  pacote           Pacote          @relation(fields: [pacote_id], references: [id])
  servico_variante ServicoVariante @relation(fields: [servico_variante_id], references: [id])
  debitos          PacoteItemDebito[]

  @@map("pacote_items")
}

model PacoteItemDebito {
  id             String   @id @default(uuid())
  agendamento_id String
  pacote_pet_id  String
  pacote_item_id String
  quantidade     Int      @default(1)
  created_at     DateTime @default(now()) @db.Timestamptz

  agendamento Agendamento @relation(fields: [agendamento_id], references: [id])
  pacote_pet  PacotePet   @relation(fields: [pacote_pet_id], references: [id])
  pacote_item PacoteItem  @relation(fields: [pacote_item_id], references: [id])

  @@unique([agendamento_id, pacote_item_id]) // idempotência RF06
  @@map("pacote_item_debitos")
}

model PacotePet {
  id              String    @id @default(uuid())
  pacote_id       String
  pet_id          String
  data_ativacao   DateTime  @db.Date
  data_expiracao  DateTime? @db.Date
  created_at      DateTime  @default(now()) @db.Timestamptz

  pacote  Pacote  @relation(fields: [pacote_id], references: [id])
  pet     Pet     @relation(fields: [pet_id], references: [id])
  debitos PacoteItemDebito[]

  @@map("pacote_pets")
}

// ---------------------------------------------------------------------------
// Agenda & Atendimentos
// ---------------------------------------------------------------------------

model Agendamento {
  id                          String             @id @default(uuid())
  petshop_id                  String
  pet_id                      String
  tutor_profile_id            String
  data_hora_inicio            DateTime           @db.Timestamptz
  duracao_total_minutos       Int
  banhista_id                 String?
  banhista_fixado_pelo_tutor  Boolean            @default(false)
  status                      AgendamentoStatus  @default(AguardandoConfirmacao)
  origem                      AgendamentoOrigem  @default(tutor)
  pago                        Boolean            @default(false)
  precisa_transporte          Boolean            @default(false)
  created_at                  DateTime           @default(now()) @db.Timestamptz
  updated_at                  DateTime           @updatedAt @db.Timestamptz

  petshop        PetShop            @relation(fields: [petshop_id], references: [id])
  pet            Pet                @relation(fields: [pet_id], references: [id])
  tutor_profile  TutorProfile       @relation(fields: [tutor_profile_id], references: [id])
  banhista       PetshopUserProfile? @relation("BanistaAgendamento", fields: [banhista_id], references: [id])

  servicos    AgendamentoServico[]
  atendimento Atendimento?
  debitos     PacoteItemDebito[]
  registros   RegistroOperacional[]
  notificacoes NotificacaoOutbox[]

  // índices críticos para disponibilidade e histórico
  @@index([petshop_id, data_hora_inicio])
  @@index([banhista_id, data_hora_inicio])
  @@index([pet_id])
  @@index([tutor_profile_id])
  @@map("agendamentos")
}

model AgendamentoServico {
  id                  String   @id @default(uuid())
  agendamento_id      String
  servico_variante_id String
  ordem               Int      @default(0)
  created_at          DateTime @default(now()) @db.Timestamptz

  agendamento      Agendamento     @relation(fields: [agendamento_id], references: [id])
  servico_variante ServicoVariante @relation(fields: [servico_variante_id], references: [id])

  @@map("agendamento_servicos")
}

model Atendimento {
  id                    String   @id @default(uuid())
  agendamento_id        String   @unique
  banhista_id           String
  observacoes_internas  String?
  observacoes_gerais    String?
  created_at            DateTime @default(now()) @db.Timestamptz
  updated_at            DateTime @updatedAt @db.Timestamptz

  agendamento Agendamento        @relation(fields: [agendamento_id], references: [id])
  banhista    PetshopUserProfile @relation("BanistaAtendimento", fields: [banhista_id], references: [id])
  servicos    AtendimentoServico[]

  @@map("atendimentos")
}

model AtendimentoServico {
  id                  String                   @id @default(uuid())
  atendimento_id      String
  servico_variante_id String
  origem              AtendimentoServicoOrigem @default(agendamento)
  ordem               Int                      @default(0)
  created_at          DateTime                 @default(now()) @db.Timestamptz

  atendimento      Atendimento     @relation(fields: [atendimento_id], references: [id])
  servico_variante ServicoVariante @relation(fields: [servico_variante_id], references: [id])

  @@map("atendimento_servicos")
}

model BloqueioAgenda {
  id          String   @id @default(uuid())
  petshop_id  String
  banhista_id String?
  data_inicio DateTime @db.Timestamptz
  data_fim    DateTime @db.Timestamptz
  motivo      String?
  created_at  DateTime @default(now()) @db.Timestamptz

  petshop PetShop @relation(fields: [petshop_id], references: [id])

  @@index([petshop_id, data_inicio])
  @@map("bloqueios_agenda")
}

// ---------------------------------------------------------------------------
// Notificações
// ---------------------------------------------------------------------------

model NotificacaoOutbox {
  id             String            @id @default(uuid())
  user_id        String
  agendamento_id String?
  canal          NotificacaoCanal  @default(email)
  tipo           NotificacaoTipo
  payload        Json
  status         NotificacaoStatus @default(pendente)
  tentativas     Int               @default(0)
  data_envio     DateTime?         @db.Timestamptz
  erro           String?
  created_at     DateTime          @default(now()) @db.Timestamptz
  updated_at     DateTime          @updatedAt @db.Timestamptz

  user        User         @relation(fields: [user_id], references: [id])
  agendamento Agendamento? @relation(fields: [agendamento_id], references: [id])

  // índice para o worker de polling
  @@index([status, created_at])
  @@map("notificacoes_outbox")
}

// ---------------------------------------------------------------------------
// Auditoria
// ---------------------------------------------------------------------------

model RegistroOperacional {
  id             String   @id @default(uuid())
  occurred_at    DateTime @default(now()) @db.Timestamptz
  actor_user_id  String?
  petshop_id     String?
  agendamento_id String?
  entity_type    String
  entity_id      String
  action         String
  metadata       Json     @default("{}")

  actor_user  User?        @relation(fields: [actor_user_id], references: [id])
  petshop     PetShop?     @relation(fields: [petshop_id], references: [id])
  agendamento Agendamento? @relation(fields: [agendamento_id], references: [id])

  @@index([petshop_id, occurred_at])
  @@index([entity_type, entity_id])
  @@map("registros_operacionais")
}
