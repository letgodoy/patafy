# Banco de dados
DATABASE_URL=postgresql://patafy:patafy@localhost:5432/patafy

# Firebase — API (servidor)
FIREBASE_PROJECT_ID=
# JSON da service account em base64 ou string (gera em Firebase Console > Configurações > Contas de serviço)
FIREBASE_SERVICE_ACCOUNT_KEY=

# Firebase — Frontend (Vite, prefixo VITE_ obrigatório)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL da API (usada pelos frontends)
VITE_API_URL=http://localhost:3000/graphql

# CORS — origens dos frontends
CORS_ORIGIN_TUTOR=http://localhost:5173
CORS_ORIGIN_PETSHOP=http://localhost:5174
CORS_ORIGIN_ADMIN=http://localhost:5175

# API
APP_BASE_URL=http://localhost:3000
PORT=3000
HOST=0.0.0.0

# Worker
POLL_INTERVAL_MS=5000

# E-mail (Resend — E09)
RESEND_API_KEY=
EMAIL_FROM=noreply@patafy.care
EMAIL_FROM_NAME=Patafy Care
EMAIL_DRY_RUN=true

# URL do web-tutor (usado nos links dos e-mails)
WEB_TUTOR_URL=http://localhost:5173
